# .env.example
# このファイルをコピーして .env を作成し、実際の値を入力してください。
# .env は絶対に Git にコミットしないこと。

NODE_ENV=production
PORT={{PORT}}

# Database
DATABASE_URL=

# Auth0（使用する場合）
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=

# OpenAI（使用する場合）
OPENAI_API_KEY=

# Supabase（使用する場合）
SUPABASE_URL=
SUPABASE_KEY=

# その他アプリ固有の環境変数を追加
